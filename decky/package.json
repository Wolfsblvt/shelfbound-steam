{
  "name": "shelfbound-decky",
  "version": "0.1.0",
  "description": "Shelfbound Decky plugin (prototype): per-storage install view + privacy-first snapshot sync, emitting the standard Shelfbound snapshot contract.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "watch": "rollup -c -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wolfsblvt/shelfbound-steam.git",
    "directory": "decky"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "shelfbound"
  ],
  "author": "Wolfsblvt",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@eslint/js": "10.0.1",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "8.64.0"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
