# Shelfbound — editor + code-style baseline.
#
# This file encodes the existing house conventions so tooling reports drift instead of inventing a new style.
# It is deliberately REPORT-ONLY for C#:
#   * `EnforceCodeStyleInBuild` is intentionally NOT set, so the IDE-style rules below do NOT run during
#     `dotnet build` and therefore cannot break the existing `-warnaserror` gate. They surface through
#     `dotnet format` / `scripts/lint.ps1 -Cs`.
#   * No analyzer (CA*) severities are escalated here. Changing C# enforcement is a separate decision.
# Decky TypeScript/TSX is formatted by Prettier; the web globs here only align indentation/EOL so Prettier
# and editors agree.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,css,scss,less,html,json,jsonc,json5,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.{csproj,props,targets}]
indent_size = 2

[*.cs]
indent_size = 4

# Using directives
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:warning

# Namespaces and braces
csharp_style_namespace_declarations = file_scoped:warning
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_prefer_braces = true:suggestion

# `this.` is not used in this codebase.
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# The code deliberately mixes `var` and explicit types. Do not force either style.
csharp_style_var_for_built_in_types = false:silent
csharp_style_var_when_type_is_apparent = false:silent
csharp_style_var_elsewhere = false:silent

# Modern C# preferences already used by the codebase. These remain suggestions, not build gates.
csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_throw_expression = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:silent
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_prefer_index_operator = true:suggestion
csharp_style_prefer_range_operator = true:suggestion

dotnet_style_readonly_field = true:suggestion
dotnet_style_namespace_match_folder = true:suggestion
dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion

[*.{Designer.cs,g.cs,generated.cs}]
generated_code = true
