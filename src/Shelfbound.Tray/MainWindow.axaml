<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Shelfbound.Tray"
        x:Class="Shelfbound.Tray.MainWindow"
        Title="Shelfbound"
        Width="720" Height="732"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#0b1020"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

  <Window.Styles>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#6366f1"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Padding" Value="16,9"/>
      <Setter Property="CornerRadius" Value="9"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#818cf8"/>
    </Style>
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="#1c2438"/>
      <Setter Property="Foreground" Value="#e2e8f0"/>
      <Setter Property="Padding" Value="16,9"/>
      <Setter Property="CornerRadius" Value="9"/>
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#141a2e"/>
      <Setter Property="BorderBrush" Value="#222b45"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="16"/>
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="#7c89a8"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="LetterSpacing" Value="0.5"/>
    </Style>
    <Style Selector="TextBlock.spec-k"><Setter Property="Foreground" Value="#8a96b4"/><Setter Property="FontSize" Value="12"/></Style>
    <Style Selector="TextBlock.spec-v"><Setter Property="Foreground" Value="#e2e8f0"/><Setter Property="FontSize" Value="12"/></Style>
    <Style Selector="CheckBox"><Setter Property="Foreground" Value="#cbd5e1"/></Style>
    <Style Selector="TextBlock.link">
      <Setter Property="Foreground" Value="#93c5fd"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="TextBlock.link:pointerover"><Setter Property="TextDecorations" Value="Underline"/></Style>
  </Window.Styles>

  <ScrollViewer>
    <StackPanel Margin="20,12,20,16" Spacing="14">

      <!-- Custom draggable title bar -->
      <Border Name="TitleBar" Background="Transparent" Padding="0,6,90,0">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Width="26" Height="26" CornerRadius="7" Background="#6366f1"/>
          <TextBlock Text="Shelfbound" FontSize="17" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Update banner (only visible while an update is downloading / ready) -->
      <Border x:Name="UpdateBanner" Classes="card" IsVisible="False" Background="#1e293b" BorderBrush="#3b82f6">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
            <TextBlock x:Name="UpdateText" Foreground="#e2e8f0" FontSize="12" TextWrapping="Wrap"/>
            <TextBlock x:Name="UpdateNotesLink" Classes="link" Text="What's new" FontSize="11" IsVisible="False"/>
          </StackPanel>
          <Button x:Name="UpdateRestartButton" Grid.Column="1" Classes="primary" Content="Restart" Margin="12,0,0,0"/>
        </Grid>
      </Border>

      <Border x:Name="DeviceTypeSetupCard" Classes="card" BorderBrush="#6366f1">
        <StackPanel Spacing="9">
          <TextBlock Classes="label" Text="DEVICE TYPE"/>
          <TextBlock x:Name="DeviceTypeSetupText" Foreground="#e2e8f0" FontSize="12" TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <ComboBox x:Name="DeviceTypeInput" Width="190"/>
            <Button x:Name="SaveDeviceTypeButton" Classes="primary" Content="Save device type"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Two-column dashboard so everything fits without scrolling -->
      <Grid ColumnDefinitions="*,*" ColumnSpacing="14">

        <!-- Left column: status + account + activity (Activity fills the remaining height) -->
        <DockPanel Grid.Column="0" LastChildFill="True">

          <Border Classes="card" DockPanel.Dock="Top">
            <StackPanel Spacing="12">
              <StackPanel Spacing="4">
                <TextBlock x:Name="StatusText" Foreground="#f1f5f9" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock x:Name="DeviceText" Foreground="#8a96b4" FontSize="12"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="SyncButton" Classes="primary" Content="Sync now"/>
                <Button x:Name="ConnectButton" Classes="ghost" Content="Connect account"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="card" DockPanel.Dock="Top" Margin="0,14,0,0">
            <StackPanel Spacing="10">
              <TextBlock Classes="label" Text="ACCOUNT"/>
              <StackPanel Spacing="2">
                <TextBlock x:Name="AccountName" Foreground="#f1f5f9" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock x:Name="AccountPlan" Foreground="#8a96b4" FontSize="12" TextWrapping="Wrap"/>
              </StackPanel>
              <StackPanel x:Name="DevicesSection" Spacing="6">
                <TextBlock Classes="label" Text="DEVICES" FontSize="10"/>
                <TextBlock x:Name="ThisDeviceText" Foreground="#cbd5e1" FontSize="12"/>
                <Button x:Name="ManageDevicesButton" Classes="ghost" Content="Manage devices in dashboard" HorizontalAlignment="Left" FontSize="12"/>
              </StackPanel>
              <Button x:Name="SignOutButton" Classes="ghost" Content="Sign out" HorizontalAlignment="Left"/>
            </StackPanel>
          </Border>

          <Border Classes="card" Margin="0,14,0,0" Padding="12">
            <DockPanel LastChildFill="True">
              <TextBlock DockPanel.Dock="Top" Classes="label" Text="ACTIVITY" Margin="0,0,0,8"/>
              <ScrollViewer MinHeight="80">
                <ItemsControl x:Name="HistoryList">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" Foreground="#a9b4cf" FontSize="11"
                                 FontFamily="Cascadia Mono,Consolas,monospace"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </Border>

        </DockPanel>

        <!-- Right column: what's shared + sync + updates -->
        <StackPanel Grid.Column="1" Spacing="14">

          <Border Classes="card">
            <StackPanel Spacing="10">
              <TextBlock Classes="label" Text="WHAT THIS DEVICE SHARES"/>
              <Grid ColumnDefinitions="72,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="spec-k" Text="OS"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Classes="spec-v" x:Name="SpecOs" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Classes="spec-k" Text="CPU"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Classes="spec-v" x:Name="SpecCpu" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Classes="spec-k" Text="Cores"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Classes="spec-v" x:Name="SpecCores"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Classes="spec-k" Text="Memory"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Classes="spec-v" x:Name="SpecRam"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Classes="spec-k" Text="GPU"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Classes="spec-v" x:Name="SpecGpu" TextWrapping="Wrap"/>
              </Grid>
              <Border Background="#10182e" CornerRadius="8" Padding="10">
                <TextBlock FontSize="11" Foreground="#94a3b8" TextWrapping="Wrap"
                           Text="Also synced: your game list, install state per device, playtime, and your Steam collections. Never synced: passwords, save files, or install paths."/>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="12">
              <TextBlock Classes="label" Text="SYNC"/>
              <CheckBox x:Name="AutoSyncCheck" Content="Sync automatically in the background"/>
              <StackPanel x:Name="IntervalRow" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Every" VerticalAlignment="Center" Foreground="#cbd5e1"/>
                <NumericUpDown x:Name="IntervalInput" Minimum="1" Maximum="1440" Increment="5" Width="120"/>
                <TextBlock Text="minutes" VerticalAlignment="Center" Foreground="#cbd5e1"/>
              </StackPanel>
              <CheckBox x:Name="StartLoginCheck" Content="Start on login"/>
              <CheckBox x:Name="StartMinimizedCheck" Content="Start hidden in the tray"/>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="10">
              <TextBlock Classes="label" Text="UPDATES"/>
              <TextBlock x:Name="UpdateStatusText" Foreground="#cbd5e1" FontSize="12" TextWrapping="Wrap"/>
              <StackPanel x:Name="UpdateActions" Orientation="Horizontal" Spacing="10">
                <Button x:Name="CheckUpdateButton" Classes="ghost" Content="Check now"/>
                <TextBlock x:Name="LastCheckedText" Foreground="#7c89a8" FontSize="11" VerticalAlignment="Center"/>
              </StackPanel>
              <CheckBox x:Name="AutoUpdateCheck" Content="Check for updates automatically"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </Grid>

      <!-- Footer: version + links (transparency for a locally-installed tool) -->
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
        <TextBlock x:Name="VersionText" Foreground="#5b6580" FontSize="11" VerticalAlignment="Center"/>
        <TextBlock Text="•" Foreground="#3b4463" FontSize="11" VerticalAlignment="Center"/>
        <TextBlock x:Name="ReleaseNotesLink" Classes="link" Text="Release notes" FontSize="11" VerticalAlignment="Center"/>
        <TextBlock Text="•" Foreground="#3b4463" FontSize="11" VerticalAlignment="Center"/>
        <TextBlock x:Name="BugReportLink" Classes="link" Text="Report a bug" FontSize="11" VerticalAlignment="Center"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Window>
